@startuml

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam defaultFontName Arial
skinparam backgroundColor white
skinparam sequenceLifeLineBorderColor #555
skinparam sequenceParticipantBorderColor #555
skinparam sequenceParticipantBackgroundColor #F0F0F0
skinparam noteBackgroundColor #FFFFCC
skinparam noteBorderColor #CCCC00

participant "Клиент" as Client
participant "Балансировщик\n(Router + Load Balancer)" as LB
participant "Service Cache\n(список инстансов)" as SC
participant "Health Checker" as HC

participant "Health Cache\n(статус инстансов)" as HCACHE
participant "Service Discovery\nClient" as SD
participant "Backend Instance" as Backend





== Основной поток обработки запроса ==

Client -> LB : 1 HTTP Request\n(GET /api/v2/users)

LB -> LB : 2 Анализ path + headers

note over LB
Routing rules
/api/v2/* -> Cluster B
X-Beta: true -> Cluster C
else -> Cluster A
end note

LB -> SC : 3 Получить instances сервиса
SC --> LB : 4 Список серверов

LB -> HCACHE : 5 Проверить health статус
HCACHE --> LB : Список healthy instances

LB -> LB : 6 Load balancing algorithm\n(Weighted Round Robin)

LB -> Backend : 7 Proxy request
Backend --> LB : 8 HTTP Response

alt Backend error (5xx / timeout)
    LB -> LB : Retry policy\n(max 2 attempts)
    LB -> Backend : Proxy request (next instance)
    Backend --> LB : HTTP Response
end

LB --> Client : 9 Return response


== Service Discovery (background sync) ==

loop Периодическая синхронизация
    SD -> SD : Получить сервисы\nиз Service Registry
    SD -> LB : Обновить список сервисов
    LB -> SC : Обновить Service Cache
end


== Health Checking ==

loop Периодические проверки
    HC -> Backend : GET /health
    Backend --> HC : 200 OK / FAIL
    HC -> HCACHE : Обновить статус instance
end

@enduml